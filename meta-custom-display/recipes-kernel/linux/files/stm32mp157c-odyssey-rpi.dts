/dts-v1/;

#include "stm32mp157c-odyssey-som.dtsi"
#include "stm32mp157c-odyssey-scmi.dtsi"

/ {
	model = "Seeed Studio Odyssey-STM32MP157C Board";
	compatible = "seeed,stm32mp157c-odyssey",
		     "seeed,stm32mp157c-odyssey-som", "st,stm32mp157";

	aliases {
		ethernet0 = &ethernet0;
		serial0 = &uart4;
        serial1 = &usart2;
	};

	chosen {
        #address-cells = <1>;
		#size-cells = <1>;
		ranges;
		stdout-path = "serial0:115200n8";

        framebuffer {
			compatible = "simple-framebuffer";
			clocks = <&rcc LTDC_PX>;
			status = "disabled";
		};
	};
};

&dcmi {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&dcmi_pins_b>;
	pinctrl-1 = <&dcmi_sleep_pins_b>;
};

&ethernet0 {
	status = "okay";
	pinctrl-0 = <&ethernet0_rgmii_pins_a>;
	pinctrl-1 = <&ethernet0_rgmii_sleep_pins_a>;
	pinctrl-names = "default", "sleep";
	phy-mode = "rgmii-id";
	max-speed = <1000>;
	phy-handle = <&phy0>;
	st,eth-clk-sel;

	snps,reset-gpio = <&gpiog 0 GPIO_ACTIVE_LOW>;
	snps,reset-active-low;
	snps,reset-delays-us = <0 30000 50000>;

	mdio0 {
		#address-cells = <1>;
		#size-cells = <0>;
		compatible = "snps,dwmac-mdio";

		phy0: ethernet-phy@7 { /* KSZ9031RN */
			reg = <7>;
		};
	};
};

&pinctrl {
	u-boot,dm-pre-reloc;
	
	i2c1_pins_mx: i2c1_mx-0 {
		pins {
			pinmux = <STM32_PINMUX('F', 14, AF5)>, /* I2C1_SCL */
					 <STM32_PINMUX('F', 15, AF5)>; /* I2C1_SDA */
			bias-disable;
			drive-open-drain;
			slew-rate = <0>;
		};
	};

	i2c1_sleep_pins_mx: i2c1_sleep_mx-0 {
		pins {
			pinmux = <STM32_PINMUX('F', 14, ANALOG)>, /* I2C1_SCL */
					 <STM32_PINMUX('F', 15, ANALOG)>; /* I2C1_SDA */
		};
	};

	usart2_pins_mx: usart2_mx-0 {
		u-boot,dm-pre-reloc;
		pins1 {
			u-boot,dm-pre-reloc;
			pinmux = <STM32_PINMUX('D', 6, AF7)>; /* USART2_RX */
			bias-disable;
		};
		pins2 {
			u-boot,dm-pre-reloc;
			pinmux = <STM32_PINMUX('F', 5, AF7)>; /* USART2_TX */
			bias-disable;
			drive-push-pull;
			slew-rate = <0>;
		};
	};

	usart2_sleep_pins_mx: usart2_sleep_mx-0 {
//		u-boot,dm-pre-reloc;
		pins {
//			u-boot,dm-pre-reloc;
			pinmux = <STM32_PINMUX('D', 6, ANALOG)>, /* USART2_RX */
					 <STM32_PINMUX('F', 5, ANALOG)>; /* USART2_TX */
		};
	};

	/* USER CODE BEGIN pinctrl */
	/* USER CODE END pinctrl */
};

/*
&i2c1 {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&i2c1_pins_a>;
	pinctrl-1 = <&i2c1_sleep_pins_a>;
	i2c-scl-rising-time-ns = <100>;
	i2c-scl-falling-time-ns = <7>;
	status = "okay";
	/delete-property/dmas;
	/delete-property/dma-names;
};
*/

&i2c1 {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&i2c1_pins_mx>;
	pinctrl-1 = <&i2c1_sleep_pins_mx>;
	i2c-scl-rising-time-ns = <100>;
	i2c-scl-falling-time-ns = <7>;
	/delete-property/dmas;
	/delete-property/dma-names;

    #address-cells = <1>;
	#size-cells = <0>;
	status = "okay";

	reg_display: reg_display@45 {
		compatible = "raspberrypi,7inch-touchscreen-panel-regulator";
		reg = <0x45>;
		gpio-controller;
		#gpio-cells = <2>;
	};
};

&sdmmc1 {
	pinctrl-names = "default", "opendrain", "sleep";
	pinctrl-0 = <&sdmmc1_b4_pins_a>;
	pinctrl-1 = <&sdmmc1_b4_od_pins_a>;
	pinctrl-2 = <&sdmmc1_b4_sleep_pins_a>;
	cd-gpios = <&gpioi 3 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
	disable-wp;
	st,neg-edge;
	bus-width = <4>;
	vmmc-supply = <&v3v3>;
	status = "okay";
};

&uart4 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart4_pins_a>;
	/delete-property/dmas;
	/delete-property/dma-names;
	status = "okay";
};

&dsi {
    #address-cells = <1>;
    #size-cells = <0>;
	status = "okay";
    ports{
    	#address-cells = <1>;
		#size-cells = <0>;
	    port@0 {
            reg = <0>;
            dsi_in: endpoint{
                remote-endpoint = <&ltdc_ep0_out>;
            };
        };
	    port@1 {
            reg = <1>;
		    dsi_out: endpoint {
			    remote-endpoint = <&bridge_in>;
		    };
	    };
    };
	bridge@0 {
		reg = <0>;
		compatible = "toshiba,tc358762";
		vddc-supply = <&reg_bridge>;
//		enable-gpios = <&gpioe 4 GPIO_ACTIVE_HIGH>;
		ports {
			#address-cells = <1>;
			#size-cells = <0>;

			port@0 {
				reg = <0>;
				bridge_in: endpoint {
					remote-endpoint = <&dsi_out>;
//                    data-lanes = <0 1>;
				};
			};

			port@1 {
				reg = <1>;
				bridge_out: endpoint {
					remote-endpoint = <&panel_in>;
				};
			};
		};
	};
};

&ltdc {
    status = "okay";

    port { 
        #address-cells = <1>;
        #size-cells = <0>;

//        ltdc_ep1_out: endpoint@1 {
//            reg = <1>;
        ltdc_ep0_out: endpoint@0 {
            reg = <0>;
            remote-endpoint = <&dsi_in>;
        };
    };
};

/ {
    panel_disp1: panel_disp1 {
	    compatible = "raspberrypi,7inch-dsi", "simple-panel";
	    backlight = <&reg_display>;
	    power-supply = <&reg_display>;

	    port {
		    panel_in: endpoint {
			    remote-endpoint = <&bridge_out>;
		    };
	    };
    };

	reg_bridge: reg_bridge {
		compatible = "regulator-fixed";
		regulator-name = "bridge_reg";
		gpio = <&reg_display 0 0>;
		vin-supply = <&reg_display>;
		enable-active-high;
	};
};

