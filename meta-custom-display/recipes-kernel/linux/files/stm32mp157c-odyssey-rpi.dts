    panel_disp1: panel_disp1 {
	    compatible = "raspberrypi,7inch-dsi";
//	    backlight = <&v3v3>;
	    power-supply = <&v3v3>;

	    port {
		    panel_in: endpoint {
			    remote-endpoint = <&bridge_out>;
		    };
	    };
    };
};
*/

&usart2 {
//	pinctrl-names = "default", "sleep";
    pinctrl-names = "default";
	pinctrl-0 = <&usart2_pins_mx>;
//	pinctrl-1 = <&usart2_sleep_pins_mx>;
	status = "okay";
};


